# ── Database (shared by ingestion pipeline and Auth/RBAC API) ──
POSTGRES_URI=postgresql://user:password@localhost:5432/crimerakshak

# ── Neo4j (ingestion pipeline) ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Auth / JWT ──
# Generate a strong secret: `openssl rand -hex 32`
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security policy ──
PASSWORD_MIN_LENGTH=8
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# ── CORS (comma-separated origins) ──
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Initial superuser (used by `python -m app.seed`) ──
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_EMAIL=admin@crimerakshak.local
FIRST_SUPERUSER_PASSWORD=ChangeMe123!
